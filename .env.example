# Copy this to .env and fill in the values

# Database — Railway will give you a persistent volume path
DATABASE_URL="file:./invoicebuddy.db"

# NextAuth — generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"

# Your Railway app URL (set after deploy)
NEXTAUTH_URL="https://your-app.railway.app"

# Stripe (get from dashboard.stripe.com)
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_FREELANCER_PRICE_ID="price_..."
STRIPE_BUSINESS_PRICE_ID="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
